{
  "name": "eduverify-png-backend",
  "version": "0.2.0",
  "private": true,
  "description": "EduVerify PNG backend — Express API, built-in SQLite, SevisPass staging SSO and automated tests.",
  "type": "commonjs",
  "main": "server.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:coverage": "vitest run --coverage",
    "diagnose:sso": "node diagnose-sso.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.7",
    "supertest": "^7.1.4",
    "vitest": "^3.2.7"
  }
}
