# EduVerify PNG backend — environment configuration.
# Copy this file to `.env` and fill in the live values before going to production.
# `.env` is gitignored; never commit real secrets.
#
# Variable names follow the DICT "Developer Integration Guide - Digital Identity
# SSO" (Configuration section). The SEVISPASS_* aliases from earlier config are
# still accepted by server.js if you prefer them.

# HTTP port the Express API listens on.
PORT=3001

# When true, the SSO server is simulated in-process (no network calls; use
# POST /api/auth/simulate-scan to complete a login). Set to false to proxy real
# OIDC4VP calls to the SSO server.
MOCK_MODE=true

# --- SSO Server Configuration (OIDC4VP) — live mode only ---
# Base URL of the Digital Identity SSO authorization server.
OIDC4VP_SERVER_URL=https://your-sso-server.com
# Client credentials issued to EduVerify PNG. The SECRET must live ONLY here on
# the server and must never be shipped to the browser.
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
# Where the SSO redirects after the wallet presents the credential (HTTPS in prod).
CALLBACK_URL=https://your-website.com/api/auth/callback

# --- Security Configuration ---
# VP-token (JWT) verification for live mode. Provide EITHER a JWKS endpoint
# (asymmetric RS256/ES256 — preferred; ask the SSO provider for its JWKS URL)
# OR a shared HS256 secret. If NEITHER is set, live logins fail closed.
SSO_JWKS_URI=
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret

# --- Allowed Origins / Callbacks (DICT: register these with the SSO admin) ---
# Comma-separated browser origins permitted to call this API (CORS allowlist).
ALLOWED_ORIGINS=http://localhost:5173
# Comma-separated callback/redirect URLs permitted after authentication.
ALLOWED_CALLBACK_URLS=https://your-website.com/api/auth/callback
# The Origin header value sent on every request to the SSO server (required by
# the SSO's CORS validation). Defaults to the first ALLOWED_ORIGINS entry.
APP_ORIGIN=http://localhost:5173

# How long an unconsumed OIDC session/state stays valid before it expires
# (DICT recommends 10 minutes).
STATE_EXPIRY_MINUTES=10
