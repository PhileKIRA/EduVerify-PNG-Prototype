# EduVerify PNG backend configuration
# Copy to backend/.env. Never commit real secrets.
NODE_ENV=development
PORT=3001
DB_PATH=./eduverify.db

# true = offline demonstration; false = real SevisPass staging
MOCK_MODE=false

OIDC4VP_SERVER_URL=https://sso.stage.sevispass.gov.pg
CLIENT_ID=your-issued-client-id

# ── System administrator ───────────────────────────────────────────
# The ONE SevisPass UID (the wallet's `sub`) that is the system admin.
# Whoever signs in with this UID becomes the administrator; there is
# exactly one. Get the UID by having that person sign in once and
# reading `sub=...` from this backend's console, then paste it here.
ADMIN_SEVIS_UID=
CLIENT_SECRET=

# Registered backend return endpoint. This is NOT the Origin header.
CALLBACK_URL=http://localhost:3001/api/auth/callback
ALLOWED_CALLBACK_URLS=http://localhost:3001/api/auth/callback

# Browser/frontend address and the exact outgoing Origin sent to SevisPass.
APP_ORIGIN=http://localhost:5173
SSO_REQUEST_ORIGIN=http://localhost:5173
AUTH_SUCCESS_URL="http://localhost:5173/#/auth/complete"
AUTH_FAILURE_URL="http://localhost:5173/#/login"

SSO_JWKS_URI=https://sso.stage.sevispass.gov.pg/.well-known/jwks.json
# Optional only when the provider explicitly uses HS256 instead of JWKS.
JWT_SECRET=
SSO_ISSUER=

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STATE_EXPIRY_MINUTES=10
APP_SESSION_MINUTES=480
COOKIE_SECURE=false
TRUST_PROXY=1
LOG_LEVEL=info
SSO_TIMEOUT_MS=12000
BODY_LIMIT=256kb

AUTH_RATE_LIMIT_MAX=20
POLL_RATE_LIMIT_MAX=40
GENERAL_RATE_LIMIT_MAX=200

# Production rejects HTTP URLs unless this explicit override is enabled.
ALLOW_INSECURE_HTTP=false
SECURITY_CONTACT=mailto:security@eduverify.example.pg
